{
  "name": "relational-lens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first relationship interpretation extension for SillyTavern.",
  "scripts": {
    "clean": "rimraf dist coverage",
    "build:js": "webpack --mode production --config webpack.config.cjs",
    "build:css": "sass src/styles/main.scss dist/style.css --no-source-map",
    "build:templates": "cp -r templates/*.html dist/",
    "build": "npm run clean && npm run build:css && npm run build:js && npm run build:templates",
    "dev:js": "webpack --mode development --config webpack.config.cjs --watch",
    "dev:css": "sass src/styles/main.scss dist/style.css --watch --source-map",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"templates/**/*.html\" \"*.json\" \"*.md\"",
    "check": "npm run typecheck && npm test && npm run build",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "sillytavern-utils-lib": "^1.0.64",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jquery": "^3.5.32",
    "@types/node": "^22.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.1",
    "sass": "^1.89.0",
    "ts-jest": "^29.3.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.0",
    "webpack": "^5.99.0",
    "webpack-cli": "^6.0.1"
  }
}
